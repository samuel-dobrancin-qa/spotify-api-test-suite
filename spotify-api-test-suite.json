    {
      "name": "Search",
      "item": [
        {
          "name": "SEARCH-01 — Valid track search",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains tracks object\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('tracks');",
                  "});",
                  "",
                  "pm.test(\"Tracks items array is not empty\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.tracks.items).to.be.an('array');",
                  "    pm.expect(jsonData.tracks.items.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"First result has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var firstTrack = jsonData.tracks.items[0];",
                  "    pm.expect(firstTrack).to.have.property('id');",
                  "    pm.expect(firstTrack).to.have.property('name');",
                  "    pm.expect(firstTrack).to.have.property('duration_ms');",
                  "    pm.expect(firstTrack).to.have.property('explicit');",
                  "});",
                  "",
                  "pm.test(\"Results respect limit parameter\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.tracks.items.length).to.be.at.most(5);",
                  "});",
                  "",
                  "// Save a track ID for later tests",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.tracks.items.length > 0) {",
                  "    pm.environment.set(\"track_id\", jsonData.tracks.items[0].id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/search?q=Radiohead&type=track&limit=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
